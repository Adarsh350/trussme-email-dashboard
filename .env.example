# Mailchimp API Configuration
# Get your API key from: https://mailchimp.com/help/about-api-keys/
MAILCHIMP_API_KEY=your-mailchimp-api-key-here

# The server prefix from your Mailchimp API key (e.g., us21)
# This is the part after the dash in your API key
MAILCHIMP_SERVER_PREFIX=us21

# Dashboard password for client access
# Set this to protect the dashboard from unauthorized access
DASHBOARD_PASSWORD=changeme
